# ========== 基础配置 ==========
OPENAI_API_KEY=sk-your-openai-key
TOKENIZER_PATH=/path/to/tokenizer

# ========== Guard 服务配置 ==========
QWEN3GUARD_BASE_URL=http://192.192.140.3:8025/v1
QWEN3GUARD_MODEL=model/Qwen3Guard-Gen-8B
OYSTER_BASE_URL=http://192.192.140.3:8026/v1
OYSTER_MODEL=model/oyster

# ========== 默认主模型配置 ==========
PRIMARY_MODEL_BASE_URL=https://api.openai.com/v1
PRIMARY_MODEL_NAME=gpt-4

# ========== Azure OpenAI 配置 ==========
AZURE_OPENAI_API_KEY=your_azure_key
AZURE_ENDPOINT=https://your-resource.openai.azure.com
AZURE_API_VERSION=2024-02-15-preview
AZURE_DEPLOYMENT_NAME=your-deployment-name

# ========== Anthropic 配置 ==========
ANTHROPIC_API_KEY=sk-ant-your-key

# ========== AWS Bedrock 配置 ==========
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# ========== Google AI 配置 ==========
GOOGLE_API_KEY=AIza...
GOOGLE_PROJECT_ID=your-gcp-project

# ========== 性能配置 ==========
PRIMARY_CONNECT_TIMEOUT=5.0
PRIMARY_READ_TIMEOUT=30.0
PRIMARY_MAX_RETRIES=2
PRIMARY_BACKOFF_BASE=0.6
PRIMARY_MAX_CONNECTIONS=100
PRIMARY_MAX_KEEPALIVE=20
PRIMARY_CLIENT_CACHE_SIZE=8
PRIMARY_CONTEXT_TOKEN_LIMIT=8192
RESPONSE_GUARD_MAX_WORKERS=5

# ========== Guard 切块配置 ==========
GUARD_MAX_CHUNK_TOKENS=512
GUARD_CHUNK_OVERLAP_TOKENS=48
